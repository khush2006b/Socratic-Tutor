# ── Gemini API Keys ──────────────────────────────────────────────
# Up to 3 keys — auto-rotates to the next key on rate-limit (429).
# At minimum, set GEMINI_API_KEY_1.
GEMINI_API_KEY_1=your-first-gemini-api-key
GEMINI_API_KEY_2=your-second-gemini-api-key
GEMINI_API_KEY_3=your-third-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── Supabase (optional) ──────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# If not set, the app runs without database persistence (in-memory only).
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── App ──────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
